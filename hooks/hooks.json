{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cc-mem recall 2>/dev/null"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_CONVERSATION\" | cc-mem save 2>/dev/null &"
          }
        ]
      }
    ]
  }
}
