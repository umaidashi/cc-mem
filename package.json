{
  "name": "cc-mem",
  "version": "0.1.0",
  "description": "Long-term memory for Claude Code — local-first, zero manual effort",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "cc-mem": "./index.ts"
  },
  "scripts": {
    "save": "bun run index.ts save",
    "search": "bun run index.ts search",
    "import": "bun run index.ts import",
    "stats": "bun run index.ts stats",
    "gc": "bun run index.ts gc",
    "test": "bun test tests/",
    "test:filter": "bun test tests/filter.test.ts",
    "test:dedup": "bun test tests/dedup.test.ts",
    "test:cleaning": "bun test tests/cleaning.test.ts",
    "test:e2e": "bash scripts/e2e-test.sh",
    "setup": "ollama pull nomic-embed-text && bun link",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}